# Binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary
*.test

# Output of the go coverage tool
*.out

# Dependency directories
vendor/

# Go workspace file
go.work

# Environment files (dotenvx)
# Dev env files are always gitignored. Prod env files should be committed after
# encrypting with `make env-encrypt`. Private keys are always gitignored.
.env
.env.local
.env.dev.core
.env.dev.svcs
.env.keys

# Claude Code
.claude/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Generated sqlc code (uncomment to ignore generated code)
# Note: Some teams prefer to commit generated code, others regenerate it
# internal/database/db/

# Generated API documentation (regenerated with make docs)
docs/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
tmp/
temp/

