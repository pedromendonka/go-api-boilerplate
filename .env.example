# Sanjow Main API - Environment Configuration
#
# Usage:
#   cp .env.example .env    # Create your local config
#   # Edit .env with your values
#   make run                # App loads .env automatically
#
# Files (all gitignored):
#   .env        - Development config (copy from this file)
#   .env.local  - Personal overrides (optional, loaded after .env)
#
# Priority: real env vars > .env.local > .env

# =============================================================================
# REQUIRED
# =============================================================================

# DATABASE_URL - PostgreSQL connection string
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://user:password@localhost:5432/sanjow?sslmode=disable

# JWT_SECRET - Secret key for signing JWT tokens
# IMPORTANT: Must be at least 32 characters for security
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-minimum-32-chars

# =============================================================================
# OPTIONAL
# =============================================================================

# SERVER_PORT - HTTP server port (default: 8080)
# Must be between 1 and 65535
SERVER_PORT=8080

# LOG_FORMAT - Log output format (default: json)
# Options: json, text
# Use "text" for local development, "json" for production
LOG_FORMAT=text

# SKIP_DB - Skip database connection (default: false)
# Set to "true" to start server without DB (for testing docs, health endpoints, etc.)
# API endpoints requiring DB will not be registered
# SKIP_DB=true

# =============================================================================
# DOCS AUTHENTICATION (optional)
# =============================================================================

# DOCS_USERNAME - Username for accessing /docs and /swagger.json
# DOCS_PASSWORD - Password for accessing /docs and /swagger.json
# If both are set, Basic Auth is required to view API documentation
# Leave empty or commented out for public docs
# DOCS_USERNAME=admin
# DOCS_PASSWORD=secret
